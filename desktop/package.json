{
  "name": "silent-p-pwsa-desktop",
  "productName": "Silent P. PWSA",
  "version": "0.2.0",
  "description": "Desktop application for Silent P. Progressive Webspace App",
  "main": "companion-bootstrap.js",
  "author": "Silent P.",
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check companion-bootstrap.js && node --check main.js && node --check preload.js && node --check security.js && node --check ../web/app.js",
    "dist:linux": "electron-builder --linux AppImage deb",
    "dist:win": "electron-builder --win nsis portable",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.fypm.silentpwebspace",
    "productName": "Silent P. PWSA",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "companion-bootstrap.js",
      "main.js",
      "preload.js",
      "security.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": ["**/*"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network;WebBrowser"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "artifactName": "Silent-P-PWSA-${version}-${os}-${arch}.${ext}"
  }
}
