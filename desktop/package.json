{
  "name": "silent-p-pwsa-desktop",
  "productName": "Silent P. PWSA",
  "version": "0.3.0",
  "description": "Desktop application for Silent P. Progressive Webspace App",
  "main": "main.js",
  "author": {
    "name": "Silent P.",
    "email": "252804653+fkdyall@users.noreply.github.com"
  },
  "homepage": "https://github.com/fkdyall/silentp.webspace",
  "repository": {
    "type": "git",
    "url": "https://github.com/fkdyall/silentp.webspace.git"
  },
  "license": "MIT",
  "private": true,
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check security.js && node --check ../web/app.js && node check-architecture.js",
    "dist:linux": "electron-builder --linux AppImage",
    "dist:win": "electron-builder --win portable",
    "dist:linux:all": "electron-builder --linux AppImage deb",
    "dist:win:all": "electron-builder --win nsis portable",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "26.15.3"
  },
  "build": {
    "appId": "com.fypm.silentpwebspace",
    "productName": "Silent P. PWSA",
    "executableName": "silent-p-pwsa",
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "security.js",
      "check-architecture.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../web",
        "to": "web",
        "filter": [
          "**/*"
        ]
      }
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Network",
      "icon": "icon-512.png",
      "maintainer": "Silent P. <252804653+fkdyall@users.noreply.github.com>"
    },
    "win": {
      "target": [
        "portable"
      ],
      "icon": "icon.ico"
    },
    "appImage": {
      "artifactName": "Silent-P-PWSA-${version}-linux-${arch}.${ext}"
    },
    "deb": {
      "artifactName": "Silent-P-PWSA-${version}-linux-${arch}.${ext}",
      "maintainer": "Silent P. <252804653+fkdyall@users.noreply.github.com>"
    },
    "portable": {
      "artifactName": "Silent-P-PWSA-${version}-windows-portable-${arch}.${ext}"
    },
    "nsis": {
      "artifactName": "Silent-P-PWSA-${version}-windows-setup-${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
